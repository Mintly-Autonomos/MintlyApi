{
  "name": "project",
  "version": "1.0.0",
  "description": "Node.js project with TypeScript and MongoDB",
  "main": "dist/server.js",
  "packageManager": "npm@11.11.0",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "start:w": "tsx watch src/server.ts",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:unit": "vitest --project unit",
    "test:int": "vitest --project integration",
    "test:cov": "vitest --run --coverage",
    "test:ci": "vitest --run --coverage",
    "test:e2e": "vitest --run --config tests/e2e/vitest.e2e.config.ts",
    "validate:swagger": "tsx scripts/validate-swagger.ts"
  },
  "engines": {
    "node": ">=22 <25"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@ascendance-hub/sapphire-core": "^1.2.0",
    "@fastify/cors": "^10.0.1",
    "fastify": "^5.0.0",
    "http-status-codes": "^2.3.0",
    "mintly-lib": "^1.1.0",
    "mongodb": "^6.3.0"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.0.0",
    "@fastify/swagger": "^9.5.2",
    "@fastify/swagger-ui": "^5.2.3",
    "@types/http-status-codes": "^1.2.0",
    "@types/node": "^20.11.5",
    "@typescript-eslint/eslint-plugin": "6.4.0",
    "@vitest/coverage-v8": "^4.1.7",
    "dotenv": "^16.4.5",
    "eslint": "8.0.1",
    "eslint-config-standard-with-typescript": "43.0.1",
    "eslint-plugin-import": "2.25.2",
    "eslint-plugin-jest": "27.9.0",
    "eslint-plugin-n": "15.0.0 || 16.0.0 ",
    "eslint-plugin-prettier": "5.1.3",
    "eslint-plugin-promise": "6.0.0",
    "ts-node": "10.9.2",
    "tsup": "^6.5.0",
    "tsx": "^4.16.2",
    "typescript": "^5.3.3",
    "vitest": "^4.0.8"
  }
}
